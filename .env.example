# X (Twitter) Account Credentials
# English account for international news
X_ENGLISH_USERNAME=your_english_account_username
X_ENGLISH_PASSWORD=your_english_account_password

# Turkish account for Turkish news  
X_TURKISH_USERNAME=your_turkish_account_username
X_TURKISH_PASSWORD=your_turkish_account_password

# Web Application Settings
FLASK_ENV=development
PORT=5000

# Deployment Settings (Optional)
# Vercel
VERCEL_TOKEN=your_vercel_token
VERCEL_ORG_ID=your_vercel_org_id  
VERCEL_PROJECT_ID=your_vercel_project_id

# Railway
RAILWAY_TOKEN=your_railway_token

# Heroku
HEROKU_API_KEY=your_heroku_api_key
HEROKU_APP_NAME=your_heroku_app_name